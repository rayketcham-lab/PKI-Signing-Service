[26.4, "o", "\u001b[2m# 200 milliseconds. Karen stares at the screen.\u001b[0m\r\n"]
[26.9, "o", "\u001b[2m# She stares for a very long time.\u001b[0m\r\n"]
[27.4, "o", "\r\n"]
[28.0, "o", "\u001b[1;33m  Karen: *puts glasses back on*\u001b[0m\r\n"]
[28.5, "o", "\u001b[1;33m          \"...acceptable.\"\u001b[0m\r\n"]
[29.0, "o", "\r\n"]
[29.3, "o", "\u001b[2m# She closes her laptop and leaves without saying goodbye.\u001b[0m\r\n"]
[29.7, "o", "\u001b[2m# This is the highest praise she has ever given.\u001b[0m\r\n"]
[30.1, "o", "\r\n"]
[30.5, "o", "\u001b[1;32m  pki-sign — Compliant enough for Karen. That means it's flawless.\u001b[0m\r\n"]
