[0.1, "o", "\u001b[2m# Tuesday, 10:00 AM sharp.\u001b[0m\r\n"]
[0.6, "o", "\u001b[2m# The calendar invite said \"Compliance Spot Check — 30 min\"\u001b[0m\r\n"]
[1.1, "o", "\u001b[2m# It has been 2 hours.\u001b[0m\r\n"]
[1.6, "o", "\r\n"]
[1.9, "o", "\u001b[1;33m  *adjusts glasses*\u001b[0m\r\n"]
[2.2, "o", "\u001b[1;33m  Karen: \"I need to verify EVERY signed artifact. Every single one.\u001b[0m\r\n"]
[2.5, "o", "\u001b[1;33m          SOC2 Type II doesn't audit itself.\"\u001b[0m\r\n"]
[2.8, "o", "\r\n"]
[3.1, "o", "\u001b[2m# Fine. Let's do this.\u001b[0m\r\n"]
