[6.1, "o", "\u001b[2m# Kevin stares at the screen. His palms are sweating.\u001b[0m\r\n"]
[6.8, "o", "\u001b[2m# He opens Slack. Types: \"hey maria what does authenticode mean\"\u001b[0m\r\n"]
[7.5, "o", "\u001b[2m# Maria sighs. She walks over.\u001b[0m\r\n"]
[8.2, "o", "\r\n"]
[8.5, "o", "\u001b[1;36m# Maria:\u001b[0m \u001b[1m\"Kevin. We have a code signing service. Here, watch.\"\u001b[0m\r\n"]
