[27.8, "o", "\u001b[2m# Kevin adds pki-sign to his dotfiles. He will never forget this day.\u001b[0m\r\n"]
[28.4, "o", "\u001b[2m# Maria goes back to her desk and writes 47 more signing pipelines.\u001b[0m\r\n"]
[29.1, "o", "\r\n"]
