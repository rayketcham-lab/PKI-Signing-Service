[13.1, "o", "\r\n"]
[13.5, "o", "\u001b[2m# The monitor flickers.\u001b[0m\r\n"]
[14.0, "o", "\u001b[2m# Chad stares at SIGNATURE INVALID for a long time.\u001b[0m\r\n"]
[14.6, "o", "\u001b[2m# He closes the laptop. Opens it again. It still says SIGNATURE INVALID.\u001b[0m\r\n"]
[15.3, "o", "\r\n"]
