[11.0, "o", "\u001b[1;31m  вң— Authenticode hash: MISMATCH\u001b[0m\r\n"]
[11.2, "o", "\u001b[1;31m    Expected: a3f8c2d19e4b7056f1234abc89def012...\u001b[0m\r\n"]
[11.4, "o", "\u001b[1;31m    Computed: 7b91e4d2c80f36a159876543fedcba98...\u001b[0m\r\n"]
[11.6, "o", "\r\n"]
[11.8, "o", "\u001b[1;31m  вң— SpcIndirectDataContent digest verification: FAILED\u001b[0m\r\n"]
