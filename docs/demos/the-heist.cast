[0.1, "o", "\u001b[2m# 2:47 AM. A basement. The glow of a monitor illuminates a hoodie.\u001b[0m\r\n"]
[0.9, "o", "\u001b[2m# Meet Chad. Self-described \"security researcher\". Eats Monster Energy for breakfast.\u001b[0m\r\n"]
