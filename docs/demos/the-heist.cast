[18.7, "o", "\u001b[2m# Chad goes to bed. He dreams of SHA-256.\u001b[0m\r\n"]
[19.3, "o", "\u001b[2m# Tomorrow he will read the Authenticode spec. All 94 pages of it.\u001b[0m\r\n"]
