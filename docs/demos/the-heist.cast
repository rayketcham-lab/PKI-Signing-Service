[12.2, "o", "\u001b[1;31m  вң— PE section .text: MODIFIED (delta at 0x00004800)\u001b[0m\r\n"]
[12.4, "o", "\r\n"]
[12.7, "o", "\u001b[1;33m  Certificate chain: valid (irrelevant вҖ” hash is wrong)\u001b[0m\r\n"]
